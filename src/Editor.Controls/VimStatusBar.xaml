<UserControl x:Class="Editor.Controls.VimStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

    <!-- Wildmenu completion bar (hidden when no completions) -->
    <Border x:Name="WildmenuBorder" Background="#44475A" Padding="6,2" Visibility="Collapsed">
        <TextBlock x:Name="WildmenuText"
                   FontFamily="Cascadia Code, Consolas" FontSize="12"
                   Foreground="#F8F8F2" TextWrapping="Wrap"/>
    </Border>

    <Grid Height="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Mode indicator -->
        <Border x:Name="ModeBorder" Grid.Column="0" Padding="8,2" MinWidth="80">
            <TextBlock x:Name="ModeText" FontFamily="Cascadia Code, Consolas" FontSize="13"
                       FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <!-- File name / Command line area -->
        <Grid Grid.Column="1">
            <TextBlock x:Name="FileText" FontFamily="Cascadia Code, Consolas" FontSize="12"
                       Foreground="#DDDDDD" VerticalAlignment="Center" Padding="8,0"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="CommandText" FontFamily="Cascadia Code, Consolas" FontSize="13"
                       Foreground="White" VerticalAlignment="Center" Padding="4,0"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Status message -->
        <TextBlock x:Name="StatusText" Grid.Column="2" FontFamily="Cascadia Code, Consolas" FontSize="12"
                   Foreground="#AAAAAA" VerticalAlignment="Center" Padding="8,0"/>

        <!-- Cursor position -->
        <TextBlock x:Name="PosText" Grid.Column="3" FontFamily="Cascadia Code, Consolas" FontSize="12"
                   Foreground="#DDDDDD" VerticalAlignment="Center" Padding="8,0" MinWidth="120" TextAlignment="Right"/>
    </Grid>
    </StackPanel>
</UserControl>
